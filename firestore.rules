rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidUser(request.resource.data);
      allow delete: if userId != 'superadmin';
    }

    match /results/{resultId} {
      allow read: if true;
      allow create: if isValidResult(request.resource.data);
      allow update: if false;
      allow delete: if true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'username', 'password', 'role', 'active'])
        && data.name is string
        && data.username is string
        && data.password is string
        && data.password.size() == 64
        && data.role in ['admin', 'docente']
        && data.active is bool;
    }

    function isValidResult(data) {
      // Agregamos 'answers' como opcional pero permitido
      return data.keys().hasAll(['id', 'name', 'email', 'institution', 'municipality', 'score', 'pct', 'grade', 'timestamp'])
        && data.score is number
        && data.pct is number
        && data.timestamp is string;
    }
  }
}
